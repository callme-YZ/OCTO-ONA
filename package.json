{
  "name": "octo-ona",
  "version": "1.1.3",
  "description": "Organizational Network Analysis framework for Human-AI collaboration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-static",
    "copy-static": "mkdir -p dist/web-ui/public && cp -r src/web-ui/public/* dist/web-ui/public/",
    "start:ui": "npm run build && node dist/web-ui/start-server.js",
    "dev": "ts-node src/index.ts",
    "dev:ui": "ts-node src/web-ui/start-server.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "ONA",
    "organizational-network-analysis",
    "human-ai-collaboration",
    "connoisseurship"
  ],
  "author": "YZ",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^5.0.6",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.3.0",
    "mysql2": "^3.11.5",
    "puppeteer": "^24.40.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
